# ============================================================
# agente-core — variables de entorno
# Copia este archivo como ".env" para correr localmente.
# En Render se configuran desde el dashboard.
# ============================================================

# --- OBLIGATORIOS ---
# Postgres compartida con la web del ministerio (misma URL).
# El servicio crea sus propias tablas (agent_missions, agent_review_requests, agent_activity_log).
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Bearer token que TODOS los agentes deben usar al llamar /api/agent/*
# En Render se genera automaticamente (generateValue: true en render.yaml).
AGENT_API_KEY=cambia-esto-en-produccion

# --- TELEGRAM (notificaciones al humano) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# --- TUNING ---
# Cuantas horas tiene Luis para aprobar antes de auto-deny
REVIEW_AUTO_DENY_HOURS=24

# Puerto local (Render lo setea solo a $PORT)
PORT=5050
